{
  "name": "prdkit-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "typecheck": "rm -rf .next && tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nextra": "4.6.1",
    "nextra-theme-docs": "4.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "lint-staged": {
    "*.{ts,tsx,mts}": [
      "prettier --write",
      "tsc --noEmit"
    ],
    "*.{ts,tsx,mts,js,jsx,mjs,cjs,mts,cts,json,less,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.0.12",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.5",
    "typescript": "^5.9.2"
  }
}
